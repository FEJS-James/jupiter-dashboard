# =============================================================================
# AgentFlow Environment Variables
# =============================================================================

# --- Turso Database (REQUIRED for production) ---
# Get these from https://turso.tech after creating a database
# Production URL looks like: libsql://your-db-name-your-org.turso.io
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# --- Local Development ---
# For local dev, you can use a local SQLite file instead of Turso:
# TURSO_DATABASE_URL=file:./data/agentflow.db
# TURSO_AUTH_TOKEN=           (leave empty for local file)

# --- Blog Database (separate Turso DB) ---
# These are SEPARATE from the task scheduler DB above
BLOG_DATABASE_URL=libsql://jupiter-blogs-your-org.turso.io
BLOG_AUTH_TOKEN=your-blog-auth-token-here
# For local dev:
# BLOG_DATABASE_URL=file:./data/blogs.db
# BLOG_AUTH_TOKEN=             (leave empty for local file)
